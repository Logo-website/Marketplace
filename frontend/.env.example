# Базовый URL REST API. Локально НЕ задавай - тогда работает относительный '/api'
# через прокси Vite на :8001. В prod (фронт и бэк на разных доменах) укажи полный
# адрес бэка с суффиксом /api, например https://marketplace-api.onrender.com/api
VITE_API_URL=

# Адрес WebSocket-сервиса (node) для живых уведомлений о заказах.
# Локально node слушает 3000. В prod - адрес за TLS, например wss://example.com/ws
VITE_WS_URL=ws://localhost:3000
