DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=marketplace
POSTGRES_USER=marketplace_user
POSTGRES_PASSWORD=your-password-here
POSTGRES_HOST=db
POSTGRES_PORT=5432
# SSL для managed-БД. Локально (Docker) оставляй пустым; на проде с Neon - require.
POSTGRES_SSLMODE=

REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
ELASTICSEARCH_URL=http://elasticsearch:9200
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CPP_SERVICE_URL=http://recommender:8080/
CPP_SERVICE_TIMEOUT=1.5
RECOMMENDER_MATRIX_PATH=/data/copurchase_matrix.txt
RESEND_API_KEY=re_your_key_here
DEFAULT_FROM_EMAIL=noreply@marketclother.ru
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173